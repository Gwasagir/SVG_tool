{
  "$schema": "https://opencode.ai/config.json",
  // PROJECT-TEMPLATE opencode config — copy this file to <repo>/.opencode/opencode.jsonc
  // and trim/extend the instructions[] array to match what the project needs.
  // Paths are relative to the project root (`.opencode/...`), so they resolve
  // wherever the project lives. Provider/model block is identical to the global
  // template at ~/.config/opencode/opencode.jsonc — adjust per-project as needed.
  "provider": {
    // All local models share port 8080. Restart llama-server to change the loaded model.
    "local": {
      "name": "Local LLM (llama.cpp + RTX 4090)",
      "options": {
        "baseURL": "http://localhost:8080/v1",
        "apiKey": "not-needed"
      },
      "models": {
        "gemma-4-31b": {
          "name": "Gemma 4 31B (Q4_K_M, llama.cpp)",
          "tool_call": true,
          "limit": { "context": 32768, "output": 8192 }
        },
        "qwen3-27b": {
          "name": "Qwen3.6 27B (Q4_K_M, llama.cpp)",
          "tool_call": true,
          "limit": { "context": 32768, "output": 8192 }
        },
        "qwen3-35b-a3b": {
          "name": "Qwen3 35B A3B (Q8_0, llama.cpp)",
          "tool_call": true,
          "limit": { "context": 262144, "output": 8192 }
        }
      }
    },
    // Ollama cloud models. Requires `ollama signin`. Daemon at :11434 proxies to ollama.com.
    "ollama": {
      "name": "Ollama Cloud",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "not-needed"
      },
      "models": {
        "kimi-k2.6:cloud": {
          "name": "Kimi K2.6 (Ollama cloud)",
          "tool_call": true,
          "limit": { "context": 262144, "output": 8192 }
        },
        "deepseek-v4-flash:cloud": {
          "name": "DeepSeek V4 Flash (Ollama cloud)",
          "tool_call": true,
          "limit": { "context": 524288, "output": 8192 }
        },
        "deepseek-v4-pro:cloud": {
          "name": "DeepSeek V4 Pro (Ollama cloud)",
          "tool_call": true,
          "limit": { "context": 524288, "output": 8192 }
        },
        "gemma4:31b-cloud": {
          "name": "Gemma 4 31B (Ollama cloud)",
          "tool_call": true,
          "limit": { "context": 262144, "output": 8192 }
        },
        "qwen3.5:cloud": {
          "name": "Qwen 3.5 (Ollama cloud)",
          "tool_call": true,
          "limit": { "context": 262144, "output": 8192 }
        },
        "glm-5.1:cloud": {
          "name": "GLM 5.1 (Ollama cloud)",
          "tool_call": true,
          "limit": { "context": 202752, "output": 8192 }
        },
        "minimax-m2.7:cloud": {
          "name": "MiniMax M2.7 (Ollama cloud)",
          "tool_call": true,
          "limit": { "context": 204800, "output": 8192 }
        },
        "nemotron-3-super:cloud": {
          "name": "Nemotron 3 Super (Ollama cloud)",
          "tool_call": true,
          "limit": { "context": 262144, "output": 8192 }
        },
        "glm-5:cloud": {
          "name": "GLM 5 (Ollama cloud) — Arena Elo leader, MIT license",
          "tool_call": true,
          "limit": { "context": 202752, "output": 8192 }
        },
        "kimi-k2.5:cloud": {
          "name": "Kimi K2.5 (Ollama cloud) — math/science champion, vision",
          "tool_call": true,
          "limit": { "context": 262144, "output": 8192 }
        },
        "minimax-m2.5:cloud": {
          "name": "MiniMax M2.5 (Ollama cloud) — top SWE-bench Verified",
          "tool_call": true,
          "limit": { "context": 204800, "output": 8192 }
        },
        "qwen3-coder-next:cloud": {
          "name": "Qwen3 Coder Next (Ollama cloud) — fast no-thinking code agent",
          "tool_call": true,
          "limit": { "context": 262144, "output": 8192 }
        },
        "gpt-oss:120b-cloud": {
          "name": "GPT-OSS 120B (Ollama cloud) — fast cheap workhorse",
          "tool_call": true,
          "limit": { "context": 131072, "output": 8192 }
        }
      }
    }
  },
  "model": "local/qwen3-35b-a3b",
  "small_model": "local/qwen3-35b-a3b",
  "default_agent": "build",
  "permission": {
    "deny": {
      "~/.ssh/**": "deny",
      "~/.aws/**": "deny",
      "~/.gnupg/**": "deny",
      "**/.env*": "deny",
      "**/credentials*": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/secrets/**": "deny",
      "**/.git/config": "deny"
    },
    "allow": {
      "bash": "ask"
    }
  },
  // Eager-load list — KIT DELTA ONLY. The global config (~/.config/opencode)
  // already eager-loads its own INSTRUCTIONS + security + testing rules and
  // always applies underneath this kit, so we never re-list those here (doing
  // so double-injects them into the system prompt). This kit adds only its own
  // coding-specific INSTRUCTIONS delta plus this project's own conventions.
  // Skills (api-design, backend-patterns, frontend-patterns, e2e-testing,
  // eval-harness, strategic-compact) are lazy — invoked via the skill tool.
  // This is a TypeScript + Node + Bun project: rely on the generic
  // build-error-resolver/code-reviewer agents; no per-language agent needed.
  "instructions": [
    ".opencode/instructions/INSTRUCTIONS.md",
    ".opencode/instructions/SVG_PROJECT.md"
  ]
}
