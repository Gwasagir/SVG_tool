{
  "$schema": "https://opencode.ai/config.json",
  // PROJECT-TEMPLATE opencode config — copy this file to <repo>/.opencode/opencode.jsonc
  // and trim/extend the instructions[] array to match what the project needs.
  // Paths are relative to the project root (`.opencode/...`), so they resolve
  // wherever the project lives.
  //
  // Providers and models are NOT declared here — they live in the global
  // ~/.config/opencode/opencode.jsonc (your personal setup). Only add a
  // `provider`/`model` block here if this project needs to override the global
  // defaults (e.g. a different local model), and never commit real API keys.
  // The `model`/`small_model` keys below are intentionally absent so the global
  // defaults flow through; uncomment and set them only to override per-project.
  // "model": "local/<your-model-id>",
  // "small_model": "local/<your-model-id>",
  "default_agent": "build",
  "permission": {
    "deny": {
      "~/.ssh/**": "deny",
      "~/.aws/**": "deny",
      "~/.gnupg/**": "deny",
      "**/.env*": "deny",
      "**/credentials*": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/secrets/**": "deny",
      "**/.git/config": "deny"
    },
    "allow": {
      "bash": "ask"
    }
  },
  // Eager-load list — KIT DELTA ONLY. The global config (~/.config/opencode)
  // already eager-loads its own INSTRUCTIONS + security + testing rules and
  // always applies underneath this kit, so we never re-list those here (doing
  // so double-injects them into the system prompt). This kit adds only its own
  // coding-specific INSTRUCTIONS delta plus this project's own conventions.
  // Skills (api-design, backend-patterns, frontend-patterns, e2e-testing,
  // eval-harness, strategic-compact) are lazy — invoked via the skill tool.
  // This is a TypeScript + Node + Bun project: rely on the generic
  // build-error-resolver/code-reviewer agents; no per-language agent needed.
  "instructions": [
    ".opencode/instructions/INSTRUCTIONS.md",
    ".opencode/instructions/SVG_PROJECT.md"
  ]
}